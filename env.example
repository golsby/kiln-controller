# Copy this file to .env for local development:
#
#   cp env.example .env
#
# .env is gitignored and must NOT exist in production, where the committed
# config.py defaults to the real kiln (simulate off, port 80).

# Run in development mode: simulated kiln, unprivileged port 8080,
# accelerated simulation. Leave unset / absent in production.
KILN_DEBUG=true

# How much faster than real time to run simulations (1 = real speed).
KILN_SIM_SPEEDUP=60

# Some dev venvs have a gevent/greenlet binary mismatch; this forces
# gevent's pure-Python implementation. Not needed on the Raspberry Pi.
PURE_PYTHON=1
