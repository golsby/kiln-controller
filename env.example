# Copy this file to .env for local, per-machine settings:
#
#   cp env.example .env
#
# .env is gitignored, so each machine has its own. The committed config.py
# defaults to the real kiln (simulate off, port 80) when these are unset.

# --- Development only (leave unset/absent on the kiln Pi) ---
# Run in development mode: simulated kiln, unprivileged port 8080,
# accelerated simulation.
KILN_DEBUG=true
# How much faster than real time to run simulations (1 = real speed).
KILN_SIM_SPEEDUP=60
# Some dev venvs have a gevent/greenlet binary mismatch; this forces
# gevent's pure-Python implementation. Not needed on the Raspberry Pi.
PURE_PYTHON=1

# --- Alerting (set on any machine you want phone alerts from, incl. the Pi) ---
# Integration Key from a PagerDuty service's "Events API V2" integration.
# Empty/unset = PagerDuty disabled. Free plan works and notifies the
# PagerDuty mobile app on your phone.
PAGERDUTY_ROUTING_KEY=
